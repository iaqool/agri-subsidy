# ── AI APIs ──────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get your key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Solana ───────────────────────────────────────────────────────
# Run `anchor deploy` and paste the Program ID here
PROGRAM_ID=

# Run `python generate_keypair.py` to generate these
ORACLE_KEYPAIR_PATH=./oracle_keypair.json
ORACLE_PUBKEY=
# Optional for cloud deploy: paste keypair JSON array here instead of file path
ORACLE_KEYPAIR_JSON=

# Your Solana deployer wallet public key
ADMIN_PUBKEY=

# Path to your Solana deployer keypair JSON (e.g. ~/.config/solana/id.json)
ADMIN_KEYPAIR_PATH=

# ── Optional ─────────────────────────────────────────────────────
# Defaults to Solana Devnet if not set
SOLANA_RPC_URL=https://api.devnet.solana.com

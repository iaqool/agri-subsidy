# ── AI APIs ──────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get your key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Solana ───────────────────────────────────────────────────────
# Run `anchor deploy` and paste the Program ID here
PROGRAM_ID=

# Run `python generate_keypair.py` to generate these
ORACLE_KEYPAIR_PATH=./oracle_keypair.json
ORACLE_PUBKEY=
# Optional for cloud deploy: paste keypair JSON array here instead of file path
ORACLE_KEYPAIR_JSON=

# Your Solana deployer wallet public key
ADMIN_PUBKEY=

# Path to your Solana deployer keypair JSON (e.g. ~/.config/solana/id.json)
ADMIN_KEYPAIR_PATH=

# ── Optional ─────────────────────────────────────────────────────
# Defaults to Solana Devnet if not set
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Security & Limits ──────────────────────────────────────────────
# Comma-separated allowed origins for CORS (no wildcard in production!)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to "1" to enable /docs and /openapi.json (disable in production)
ENABLE_DOCS=1
# Set to "1" in production to block /api/demo/seed
DISABLE_DEMO=0
# Capacity limits
MAX_FARMERS=10000
MAX_EVALUATIONS=50000
MAX_CONCURRENT_SSE=200
